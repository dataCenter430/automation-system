# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://oporeuhdhozrowdkeyyq.supabase.co

# New-style API keys. The SECRET key bypasses RLS — worker + Next.js API routes only.
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

NEXT_PUBLIC_SUPABASE_URL=https://oporeuhdhozrowdkeyyq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Management API token (schema migrations only — not used at runtime).
SUPABASE_ACCESS_TOKEN=sbp_...

# ── Paths ───────────────────────────────────────────────────────────────────
# The folder containing documentation/, Working/, Accepted/.
# Defaults to this repo's parent. Set it if the target machine lays things out differently.
# SNORKEL_ROOT=E:/Work/Snorkel

# ── Chrome ──────────────────────────────────────────────────────────────────
# Playwright can ONLY attach to a Chrome that was STARTED with --remote-debugging-port,
# and Chrome 136+ refuses that flag on the default user-data-dir. So we use a dedicated
# profile dir, cloned from your real one (cookies and login intact):
#   powershell -File scripts/clone-chrome-profile.ps1 -SourceProfile "Rickie"
#   powershell -File scripts/launch-chrome.ps1
CDP_URL=http://127.0.0.1:9222
CHROME_AUTOMATION_PROFILE=${SNORKEL_ROOT}/.chrome-automation-profile

# ── Claude ──────────────────────────────────────────────────────────────────
# NO API KEY. The Agent SDK spawns the Claude Code CLI, which uses the same ~/.claude
# credentials your VS Code Claude extension wrote when it signed in to claude.ai.
# The worker must run as the SAME OS user that is signed in.
